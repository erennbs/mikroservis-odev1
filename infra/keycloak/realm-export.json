{
  "realm": "etiya",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 1800,
  "roles": {
    "realm": [
      {
        "name": "USER",
        "description": "Standart kullanici: okuma (GET) yetkisi"
      },
      {
        "name": "ADMIN",
        "description": "Yonetici: okuma + yazma (POST/PUT/DELETE) yetkisi"
      }
    ]
  },
  "clients": [
    {
      "clientId": "etrade-client",
      "name": "eTrade Client",
      "description": "Mikroservislerden token almak icin kullanilan client (public, direct access grants).",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@etiya.com",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["ADMIN", "USER"]
    },
    {
      "username": "user",
      "enabled": true,
      "emailVerified": true,
      "email": "user@etiya.com",
      "firstName": "Standart",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "user123",
          "temporary": false
        }
      ],
      "realmRoles": ["USER"]
    }
  ]
}
